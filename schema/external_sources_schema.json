{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CIVID External Source Record",
  "description": "Unified schema for records extracted from Wikipedia, The Guardian, and Al Jazeera. Every record retains citation, timestamp, and license metadata.",
  "type": "object",
  "properties": {
    "record_id":            { "type": "string" },
    "source_name":          { "type": "string" },
    "source_type":          { "type": "string", "enum": ["wikipedia", "guardian", "aljazeera"] },
    "source_url":           { "type": ["string", "null"], "format": "uri" },
    "source_date":          { "type": ["string", "null"], "format": "date-time" },
    "source_license":       { "type": ["string", "null"] },
    "source_access_method": { "type": "string", "enum": ["api", "rss", "html_fallback"] },
    "title":                { "type": ["string", "null"] },
    "subtitle":             { "type": ["string", "null"] },
    "author":               { "type": ["string", "null"] },
    "publication_date":     { "type": ["string", "null"], "format": "date-time" },
    "section":              { "type": ["string", "null"] },
    "tags":                 { "type": "array", "items": { "type": "string" } },
    "categories":           { "type": "array", "items": { "type": "string" } },
    "summary":              { "type": ["string", "null"] },
    "full_text":            { "type": ["string", "null"] },
    "image_url":            { "type": ["string", "null"], "format": "uri" },
    "image_caption":        { "type": ["string", "null"] },
    "image_license":        { "type": ["string", "null"] },
    "page_id":              { "type": ["integer", "null"] },
    "revision_id":          { "type": ["integer", "null"] },
    "language":             { "type": "string", "default": "en" },
    "extraction_status":    { "type": "string", "enum": ["ok", "partial", "failed", "queued_review"] },
    "confidence_score":     { "type": "number", "minimum": 0, "maximum": 1 },
    "notes":                { "type": ["string", "null"] },
    "checksum":             { "type": ["string", "null"] },
    "duplicate_flag":       { "type": "boolean", "default": false }
  },
  "required": ["record_id", "source_name", "source_type", "source_access_method", "extraction_status"],
  "additionalProperties": false
}
